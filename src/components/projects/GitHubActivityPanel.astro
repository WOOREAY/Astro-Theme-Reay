---
/**
 * GitHubActivityPanel
 * Contribution heatmap and compact GitHub activity overview.
 */
import type { GitHubContributionCalendar } from '../../utils/github';

interface Props {
  calendar: GitHubContributionCalendar;
  languages: Array<{ name: string; count: number; color: string }>;
}

const { calendar, languages } = Astro.props;

const sourceLabel = {
  graphql: 'Contribution Calendar',
  events: 'Public Activity',
  repos: 'Repository Updates',
  cache: 'Cached Activity',
  empty: 'No Activity',
}[calendar.source];
---

<section class="github-activity reay-card">
  <div class="activity-header">
    <div>
      <p class="activity-eyebrow" data-i18n="projects.activity.eyebrow">GitHub Activity</p>
      <h2 data-i18n="projects.activity.title">Contribution Heatmap</h2>
    </div>
    <a class="activity-profile reay-button" href={`https://github.com/${calendar.username}`} target="_blank" rel="noopener noreferrer">
      <i class="i-carbon:logo-github"></i>
      <span>@{calendar.username}</span>
    </a>
  </div>

  <div class="activity-grid">
    <div class="heatmap-card">
      <div class="heatmap-summary">
        <div>
          <strong>{calendar.totalContributions}</strong>
          <span data-i18n="projects.activity.contributions">contributions</span>
        </div>
        <span class="source-chip">{sourceLabel}</span>
      </div>

      <div class="heatmap-scroll" aria-label="GitHub contribution heatmap">
        <div class="heatmap">
          {calendar.weeks.map(week => (
            <div class="heatmap-week">
              {week.map(day => (
                <span
                  class={`heatmap-day level-${day.level}`}
                  title={`${day.date}: ${day.count}`}
                  aria-label={`${day.date}: ${day.count}`}
                ></span>
              ))}
            </div>
          ))}
        </div>
      </div>

      <div class="heatmap-legend">
        <span data-i18n="projects.activity.less">Less</span>
        {[0, 1, 2, 3, 4].map(level => <span class={`legend-cell level-${level}`}></span>)}
        <span data-i18n="projects.activity.more">More</span>
      </div>
    </div>

    <div class="activity-side">
      <div class="activity-stats">
        <div class="activity-stat">
          <span>{calendar.activeDays}</span>
          <p data-i18n="projects.activity.activeDays">Active Days</p>
        </div>
        <div class="activity-stat">
          <span>{calendar.longestStreak}</span>
          <p data-i18n="projects.activity.longestStreak">Longest Streak</p>
        </div>
        <div class="activity-stat">
          <span>{calendar.currentStreak}</span>
          <p data-i18n="projects.activity.currentStreak">Current Streak</p>
        </div>
      </div>

      <div class="language-panel">
        <div class="panel-title">
          <i class="i-carbon:code"></i>
          <span data-i18n="projects.activity.languages">Language Mix</span>
        </div>
        <div class="language-list">
          {languages.length > 0 ? languages.map(language => (
            <div class="language-row">
              <span class="language-dot" style={`--language-color: ${language.color}`}></span>
              <span class="language-name">{language.name}</span>
              <span class="language-count">{language.count}</span>
            </div>
          )) : (
            <p class="empty-language" data-i18n="projects.activity.noLanguages">No language data yet</p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .github-activity {
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .activity-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .activity-eyebrow {
    margin: 0 0 0.25rem;
    color: var(--md-sys-color-primary);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .activity-header h2 {
    margin: 0;
    color: var(--md-sys-color-on-surface);
    font-size: 1.35rem;
    line-height: 1.2;
  }

  .activity-profile {
    white-space: nowrap;
  }

  .activity-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: 1rem;
  }

  .heatmap-card,
  .activity-side,
  .language-panel {
    border: 1px solid rgba(var(--md-sys-color-outline-variant-rgb), 0.28);
    border-radius: 1rem;
    background: rgba(var(--md-sys-color-surface-container-rgb), 0.36);
  }

  .heatmap-card {
    padding: 1rem;
    min-width: 0;
  }

  .heatmap-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .heatmap-summary strong {
    display: block;
    color: var(--md-sys-color-on-surface);
    font-size: 1.5rem;
    line-height: 1;
  }

  .heatmap-summary span {
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .source-chip {
    padding: 0.35rem 0.65rem;
    border: 1px solid rgba(var(--md-sys-color-primary-rgb), 0.28);
    border-radius: 999px;
    background: rgba(var(--md-sys-color-primary-container-rgb), 0.24);
    color: var(--md-sys-color-primary) !important;
  }

  .heatmap-scroll {
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  .heatmap {
    display: flex;
    gap: 0.24rem;
    min-width: max-content;
  }

  .heatmap-week {
    display: grid;
    grid-template-rows: repeat(7, 0.72rem);
    gap: 0.24rem;
  }

  .heatmap-day,
  .legend-cell {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 0.18rem;
    background: rgba(var(--md-sys-color-outline-variant-rgb), 0.22);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  .level-1 { background: rgba(var(--md-sys-color-primary-rgb), 0.24); }
  .level-2 { background: rgba(var(--md-sys-color-primary-rgb), 0.42); }
  .level-3 { background: rgba(var(--md-sys-color-primary-rgb), 0.68); }
  .level-4 { background: var(--md-sys-color-primary); }

  .heatmap-legend {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.28rem;
    margin-top: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .activity-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
  }

  .activity-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.65rem;
  }

  .activity-stat {
    min-width: 0;
    padding: 0.8rem 0.55rem;
    border-radius: 0.85rem;
    background: rgba(var(--md-sys-color-surface-rgb), 0.42);
    text-align: center;
  }

  .activity-stat span {
    display: block;
    color: var(--md-sys-color-primary);
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1;
  }

  .activity-stat p {
    margin: 0.35rem 0 0;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .language-panel {
    padding: 0.9rem;
  }

  .panel-title,
  .language-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .panel-title {
    margin-bottom: 0.65rem;
    color: var(--md-sys-color-on-surface);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .language-list {
    display: grid;
    gap: 0.5rem;
  }

  .language-row {
    min-width: 0;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .language-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: var(--language-color, var(--md-sys-color-primary));
  }

  .language-name {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .empty-language {
    margin: 0;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.8rem;
  }

  @media (max-width: 920px) {
    .activity-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .github-activity {
      padding: 1rem;
    }

    .activity-header {
      flex-direction: column;
    }
  }
</style>
