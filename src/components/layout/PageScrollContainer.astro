---
/**
 * PageScrollContainer.astro
 * 全屏滚动容器组件
 * - 负责管理全屏分页滚动的布局结构
 * - 包含滚动指示器
 */

interface Props {
  sections: Array<{
    id: string;
    label: string;
  }>;
}

const { sections } = Astro.props;
---

<!-- 全屏分页滚动容器 - 添加padding-top避免被Header遮挡 -->
<div id="fullpage-container" class="fullpage-wrapper">
  <slot />
</div>

<!-- 分页指示器 -->
<div class="section-dots fixed right-6 top-1/2 -translate-y-1/2 z-30 flex flex-col gap-3" aria-label="页面分区导航">
  {sections.map((section, index) => (
    <button 
      class="section-dot"
      data-target={index.toString()}
      aria-label={`跳转到${section.label}区域`}
    ></button>
  ))}
</div>

<style>
  .fullpage-wrapper {
    height: 100%;
    /* height: calc(100dvh-4rem); */
    overflow: hidden;
    position: relative;
  }

  .section-dots {
    padding: 0.65rem 0.45rem;
    border: 1px solid rgba(var(--md-sys-color-outline-variant-rgb), 0.34);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(var(--md-sys-color-surface-rgb), 0.56), rgba(var(--md-sys-color-surface-container-rgb), 0.34));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 18px 38px -30px rgba(0, 0, 0, 0.68);
    backdrop-filter: blur(18px) saturate(150%);
    -webkit-backdrop-filter: blur(18px) saturate(150%);
  }

  .section-dot {
    position: relative;
    width: 0.58rem;
    height: 0.58rem;
    border: 1px solid rgba(var(--md-sys-color-on-surface-variant-rgb), 0.46);
    border-radius: 999px;
    background: rgba(var(--md-sys-color-surface-container-highest-rgb), 0.48);
    cursor: pointer;
    transition:
      width 0.35s var(--reay-ease-spring, ease),
      height 0.35s var(--reay-ease-spring, ease),
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .section-dot::after {
    content: '';
    position: absolute;
    inset: -0.45rem;
    border-radius: inherit;
  }

  .section-dot:hover {
    border-color: rgba(var(--md-sys-color-primary-rgb), 0.72);
    transform: scale(1.18);
  }

  /* 激活的分页指示器 */
  .section-dot.active {
    width: 0.72rem;
    height: 1.55rem;
    background: linear-gradient(180deg, var(--md-sys-color-primary), var(--md-sys-color-tertiary));
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow:
      0 0 18px rgba(var(--md-sys-color-primary-rgb), 0.62),
      inset 0 1px 0 rgba(255, 255, 255, 0.38);
  }

  @media (max-width: 768px) {
    .section-dots {
      right: 0.75rem;
      gap: 0.55rem;
      padding: 0.5rem 0.35rem;
    }
  }
</style>

<script>
  import { initFullPageScroll } from '../../scripts/navigation/fullpage-scroll';
  
  // 初始化全屏滚动
  initFullPageScroll();
</script>
