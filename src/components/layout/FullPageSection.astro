---
/**
 * FullpageSection.astro
 * 全屏滚动的单个区块组件
 */
interface Props {
  sectionId: string;
}

const { sectionId } = Astro.props;
---

<div class="fullpage-section" data-section={sectionId}>
  <slot />
</div>

<style>
  .fullpage-section {
    height: 100%;
    width: 100%;
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translate3d(0, 100%, 0);
    transition: none;
    will-change: transform, opacity;
    overflow-y: hidden;
    overflow-x: hidden;
    overscroll-behavior: contain;
    scroll-behavior: auto;
  }

  .fullpage-section:first-of-type {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .fullpage-section[data-active='true'] {
    opacity: 1;
  }

  .fullpage-section[data-ready='true'] {
      transition:
      transform 0.76s cubic-bezier(0.2, 0.82, 0.24, 1),
      opacity 0.48s ease;
  }
</style>
