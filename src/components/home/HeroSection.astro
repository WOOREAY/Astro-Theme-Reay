---
/**
 * HeroSection Component
 * Fullscreen hero section with typewriter effects
 * Layout: text content (left) + avatar (right)
 */
import { getLocalizedUserContent, getUserProfile } from '../../data/site.config';
import { useI18n } from '../../utils/i18n';

const { t, currentLang } = useI18n();
const user = getUserProfile();
const userContent = getLocalizedUserContent(currentLang);
---

<section class="hero-section h-full w-full flex items-center justify-center relative overflow-hidden">
  <div class="hero-light hero-light-a" aria-hidden="true"></div>
  <div class="hero-light hero-light-b" aria-hidden="true"></div>
  <div class="hero-scanline" aria-hidden="true"></div>
  
  <div class="container mx-auto px-4 sm:px-6 max-w-6xl relative z-10 pt-12 md:pt-0">
    <div class="grid grid-cols-1 lg:grid-cols-[1.08fr_0.92fr] gap-8 lg:gap-12 items-center">
      <!-- Text Content -->
      <div class="hero-copy text-left space-y-5">
        <div class="status-pill inline-flex items-center gap-2 px-3 py-1.5 text-xs font-700 text-[var(--md-sys-color-primary)]">
          <span class="status-dot"></span>
          <span data-i18n="home.hero.badge">{t('home.hero.badge')}</span>
        </div>

        <!-- Title with typewriter effect -->
        <div class="min-h-[76px] sm:min-h-[96px]">
          <h1 class="hero-title text-3xl sm:text-4xl md:text-5xl font-900 leading-[1.04]">
            <span class="text-[var(--md-sys-color-on-surface)]" data-i18n="home.hero.greeting">{t('home.hero.greeting')}</span>
            <span class="text-[var(--md-sys-color-on-surface)]"> </span>
            <span 
              id="name-typewriter"
              class="name-gradient bg-gradient-to-r from-[var(--md-sys-color-primary)] via-[var(--md-ref-palette-warning)] to-[var(--md-sys-color-tertiary)] bg-clip-text text-transparent"
              data-text={user.name}
            ></span>
            <span class="title-icon inline-grid place-items-center align-middle ml-2">
              <i class="i-carbon:sun text-[1.1rem] sm:text-[1.35rem]"></i>
            </span>
          </h1>
        </div>

        <!-- Description with typewriter effect -->
        <div class="min-h-[44px]">
          <p 
            id="description-typewriter"
            class="hero-tagline text-sm sm:text-base text-[var(--md-sys-color-on-surface-variant)] font-500 italic"
            data-text={userContent.tagline}
            data-user-content="tagline"
          ></p>
        </div>

        <!-- Bio with fade-in effect -->
        <div 
          id="bio-content"
          class="min-h-[60px] opacity-0 translate-y-[10px]"
        >
          <p class="hero-bio text-sm sm:text-base text-[var(--md-sys-color-on-surface-variant)] font-500 leading-relaxed max-w-2xl" data-user-content="bio">
            {userContent.bio}
          </p>
        </div>

        <div class="hero-actions flex flex-wrap items-center gap-3 pt-1">
          <a href="/projects" class="hero-primary-btn group">
            <span data-i18n="home.hero.projects">{t('home.hero.projects')}</span>
            <i class="i-carbon:arrow-right text-lg group-hover:translate-x-1 transition-transform"></i>
          </a>
          <a href="/blog" class="hero-secondary-btn group">
            <i class="i-carbon:blog text-lg"></i>
            <span data-i18n="home.hero.blog">{t('home.hero.blog')}</span>
          </a>
        </div>

        <!-- Social icons with scale animation -->
        <div id="social-icons-container" class="pt-1">
          <div class="flex items-center gap-2.5">
            {user.socials.map((social, index) => (
              <a 
                href={social.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="social-icon group relative opacity-0 scale-80"
                style={`animation-delay: ${index * 100}ms;`}
                aria-label={social.label}
                title={social.label}
              >
                <div class="social-button inline-flex items-center justify-center w-10 h-10 rounded-full">
                  <i class={`${social.icon} text-base text-[var(--md-sys-color-on-surface-variant)] group-hover:text-[var(--md-sys-color-primary)] transition-colors`}></i>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- 右侧：大头像 -->
      <div class="flex items-center justify-center lg:justify-end">
        <div class="relative avatar-container hero-avatar-stage">
          <div class="avatar-holo-frame" aria-hidden="true"></div>
          <div class="avatar-panel-lines" aria-hidden="true"></div>
          <!-- 头像 -->
          <div class="avatar-image-wrap relative">
            <img 
              src={user.avatar} 
              alt={user.name}
              class="relative w-36 h-36 sm:w-44 sm:h-44 lg:w-56 lg:h-56 rounded-full object-cover"
            />
          </div>
          <div class="avatar-caption hidden sm:flex items-center gap-2">
            <i class="i-carbon:development text-base text-[var(--md-sys-color-primary)]"></i>
            <span data-i18n="home.hero.caption">{t('home.hero.caption')}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 滚动提示 -->
  <div class="scroll-cue absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1">
    <span class="text-xs text-[var(--md-sys-color-on-surface-variant)]" data-i18n="home.hero.scroll">{t('home.hero.scroll')}</span>
    <i class="i-carbon:chevron-down text-xl text-[var(--md-sys-color-on-surface-variant)]"></i>
  </div>
</section>

<style>
  .hero-section {
    perspective: 1200px;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 10% 4% 8%;
    background:
      linear-gradient(90deg, transparent, rgba(var(--md-sys-color-primary-rgb), 0.1), transparent),
      linear-gradient(180deg, rgba(var(--md-sys-color-on-surface-rgb), 0.06) 1px, transparent 1px);
    background-size: 100% 100%, 100% 44px;
    mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
    opacity: 0.64;
    transform: rotate(-2deg);
  }

  .hero-light {
    position: absolute;
    inset: auto;
    pointer-events: none;
    opacity: 0.78;
    filter: blur(18px);
    mix-blend-mode: screen;
  }

  .hero-light-a {
    width: 52vw;
    height: 34vh;
    left: -10vw;
    top: 18vh;
    background: linear-gradient(100deg, rgba(var(--md-sys-color-primary-rgb), 0.24), transparent 70%);
    animation: hero-light-shift 10s ease-in-out infinite alternate;
  }

  .hero-light-b {
    width: 48vw;
    height: 42vh;
    right: -8vw;
    bottom: 12vh;
    background: linear-gradient(250deg, rgba(var(--md-sys-color-tertiary-rgb), 0.2), rgba(var(--md-ref-palette-warning-rgb), 0.1), transparent 72%);
    animation: hero-light-shift 13s ease-in-out infinite alternate-reverse;
  }

  .hero-scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.09), transparent);
    transform: translateY(-100%);
    animation: scanline 7s ease-in-out infinite;
    opacity: 0.4;
  }

  .hero-copy {
    animation: hero-copy-in 0.9s var(--reay-ease-out, ease) both;
  }

  .status-pill,
  .hero-secondary-btn,
  .social-button,
  .avatar-caption {
    border: 1px solid rgba(var(--md-sys-color-outline-variant-rgb), 0.38);
    background: rgba(var(--md-sys-color-surface-container-rgb), 0.48);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 16px 36px -28px rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(18px) saturate(150%);
    -webkit-backdrop-filter: blur(18px) saturate(150%);
  }

  .status-pill {
    border-radius: 999px;
    letter-spacing: 0;
  }

  .status-dot {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: var(--md-ref-palette-success);
    box-shadow: 0 0 14px rgba(var(--md-ref-palette-success-rgb), 0.8);
    animation: status-pulse 1.8s ease-in-out infinite;
  }

  .hero-title {
    letter-spacing: 0;
    text-wrap: balance;
  }

  .name-gradient {
    position: relative;
    filter: drop-shadow(0 12px 30px rgba(var(--md-sys-color-primary-rgb), 0.24));
    background-size: 180% 100%;
    animation: name-gradient-flow 4.8s ease-in-out infinite alternate;
  }

  .title-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.7rem;
    color: var(--md-ref-palette-warning);
    background: rgba(var(--md-ref-palette-warning-rgb), 0.14);
    border: 1px solid rgba(var(--md-ref-palette-warning-rgb), 0.28);
    box-shadow: 0 0 22px rgba(var(--md-ref-palette-warning-rgb), 0.22);
  }

  .hero-tagline {
    max-width: 40rem;
  }

  .hero-bio {
    padding-left: 1rem;
    border-left: 2px solid rgba(var(--md-sys-color-primary-rgb), 0.42);
  }

  .hero-primary-btn,
  .hero-secondary-btn {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 800;
    transition:
      transform 0.3s var(--reay-ease-spring, ease),
      box-shadow 0.3s ease,
      background 0.3s ease;
  }

  .hero-primary-btn {
    color: var(--md-sys-color-on-primary);
    background:
      linear-gradient(135deg, var(--md-sys-color-primary), var(--md-sys-color-tertiary));
    box-shadow:
      0 18px 40px -18px rgba(var(--md-sys-color-primary-rgb), 0.8),
      inset 0 1px 0 rgba(255, 255, 255, 0.32);
  }

  .hero-primary-btn:hover,
  .hero-secondary-btn:hover {
    transform: translateY(-2px) scale(1.03);
  }

  .hero-secondary-btn:hover {
    color: var(--md-sys-color-primary);
    background: rgba(var(--md-sys-color-primary-container-rgb), 0.42);
  }

  .social-button {
    transition:
      transform 0.3s var(--reay-ease-spring, ease),
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
  }

  .social-icon:hover .social-button {
    border-color: rgba(var(--md-sys-color-primary-rgb), 0.48);
    background: rgba(var(--md-sys-color-primary-container-rgb), 0.38);
    box-shadow: 0 18px 34px -18px rgba(var(--md-sys-color-primary-rgb), 0.7);
    transform: translateY(-3px) rotate(-2deg);
  }

  .hero-avatar-stage {
    width: min(74vw, 23rem);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: 2rem;
    transform-style: preserve-3d;
  }

  .avatar-holo-frame {
    position: absolute;
    inset: 0.5rem;
    border-radius: 2rem;
    background:
      linear-gradient(rgba(var(--md-sys-color-surface-container-rgb), 0.38), rgba(var(--md-sys-color-surface-container-rgb), 0.18)) padding-box,
      conic-gradient(from var(--avatar-angle, 0deg), var(--md-sys-color-primary), transparent 22%, var(--md-ref-palette-warning), transparent 52%, var(--md-sys-color-tertiary), var(--md-sys-color-primary)) border-box;
    border: 1px solid transparent;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 28px 70px -44px rgba(var(--md-sys-color-primary-rgb), 0.9);
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    animation: avatar-angle 8s linear infinite;
  }

  .avatar-panel-lines {
    position: absolute;
    inset: 2rem;
    border-radius: 1.4rem;
    background:
      linear-gradient(90deg, rgba(var(--md-sys-color-on-surface-rgb), 0.08) 1px, transparent 1px),
      linear-gradient(rgba(var(--md-sys-color-on-surface-rgb), 0.07) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: linear-gradient(135deg, transparent, #000 22% 78%, transparent);
    opacity: 0.5;
  }

  .avatar-image-wrap {
    display: grid;
    place-items: center;
    padding: 0.55rem;
    border-radius: 999px;
    background:
      linear-gradient(rgba(var(--md-sys-color-surface-rgb), 0.72), rgba(var(--md-sys-color-surface-container-rgb), 0.58)) padding-box,
      conic-gradient(from 90deg, var(--md-sys-color-primary), var(--md-ref-palette-warning), var(--md-sys-color-tertiary), var(--md-sys-color-primary)) border-box;
    border: 2px solid transparent;
    box-shadow:
      0 26px 52px -28px rgba(0, 0, 0, 0.72),
      0 0 42px rgba(var(--md-sys-color-primary-rgb), 0.24);
    transform: translateZ(48px);
    animation: avatar-float 4.8s ease-in-out infinite;
  }

  .avatar-image-wrap img {
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.24);
  }

  .avatar-caption {
    position: absolute;
    right: -0.4rem;
    bottom: 3.2rem;
    min-height: 2.5rem;
    padding: 0 0.9rem;
    border-radius: 999px;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .scroll-cue {
    animation: scroll-cue 1.8s ease-in-out infinite;
  }

  /* Typewriter cursor animation */
  #name-typewriter::after,
  #description-typewriter::after {
    content: '|';
    animation: blink 0.8s step-end infinite;
    margin-left: 2px;
  }

  #name-typewriter.typing-complete::after,
  #description-typewriter.typing-complete::after {
    display: none;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Bio fade-up animation */
  #bio-content.fade-up {
    animation: fadeUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Social icon fade-scale animation */
  .social-icon.fade-scale {
    animation: fadeScale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes fadeScale {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Avatar container fade-in animation */
  .avatar-container {
    animation: fadeIn 1s ease-out 0.5s backwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hero-light-shift {
    from { transform: translate3d(-2%, -3%, 0) skewX(-8deg); }
    to { transform: translate3d(4%, 4%, 0) skewX(8deg); }
  }

  @keyframes scanline {
    0%, 48% { transform: translateY(-100%); opacity: 0; }
    58% { opacity: 0.36; }
    78%, 100% { transform: translateY(100%); opacity: 0; }
  }

  @keyframes status-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.58; }
  }

  @keyframes name-gradient-flow {
    from { background-position: 0% 50%; }
    to { background-position: 100% 50%; }
  }

  @property --avatar-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes avatar-angle {
    to { --avatar-angle: 360deg; }
  }

  @keyframes avatar-float {
    0%, 100% { transform: translateZ(48px) translateY(0) rotate(-1deg); }
    50% { transform: translateZ(48px) translateY(-10px) rotate(1deg); }
  }

  @keyframes scroll-cue {
    0%, 100% { transform: translate(-50%, 0); opacity: 0.72; }
    50% { transform: translate(-50%, 6px); opacity: 1; }
  }

  @media (max-width: 1024px) {
    .hero-copy {
      text-align: center;
    }

    .hero-tagline,
    .hero-bio {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-bio {
      padding-left: 0;
      border-left: 0;
    }

    .hero-actions,
    #social-icons-container > div {
      justify-content: center;
    }

    .hero-avatar-stage {
      width: min(68vw, 19rem);
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      align-items: flex-start;
      padding-top: 1.25rem;
    }

    .hero-title {
      line-height: 1.08;
    }

    .hero-avatar-stage {
      width: min(72vw, 15.5rem);
      border-radius: 1.35rem;
    }

    .avatar-holo-frame {
      border-radius: 1.35rem;
    }

    .avatar-caption {
      display: none;
    }

    .scroll-cue {
      bottom: 1rem;
    }
  }
</style>

<script>
  import { initTypewriterEffect } from '../../scripts/animations/typewriter-effect';
  import { initI18n } from '../../scripts/i18n-content-updater';
  import { initUserContentI18n } from '../../scripts/i18n-user-content';
  
  // IMPORTANT: Initialize user content BEFORE typewriter effect
  // This ensures the correct language content is loaded before animation starts
  initUserContentI18n();
  initI18n();
  initTypewriterEffect();
</script>
