---
/**
 * ThemeToggle.astro
 * 精致圆润风格主题切换按钮：light / dark / system
 * 更小巧、更优雅的图标按钮
 */
---
<button
  class="theme-toggle inline-flex items-center justify-center w-9 h-9 cursor-pointer"
  aria-label="切换主题"
  title="切换主题"
  data-theme-toggle>
  <i class="theme-icon i-carbon:sun text-[1.25rem] transition-transform duration-300" data-theme-icon></i>
</button>

<style>
  .theme-toggle {
    border-radius: 0.8rem;
    border: 1px solid var(--reay-button-border, rgba(var(--md-sys-color-outline-variant-rgb), 0.36));
    background: var(--reay-button-bg, rgba(var(--md-sys-color-surface-container-rgb), 0.52));
    color: var(--md-sys-color-on-surface);
    box-shadow: var(--reay-button-shadow, inset 0 1px 0 rgba(255, 255, 255, 0.16));
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    transition: transform 0.25s var(--reay-ease-out, ease), background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }

  .theme-toggle:hover {
    color: var(--md-sys-color-primary);
    transform: translateY(-1px);
    box-shadow: var(--reay-button-shadow-hover, 0 16px 32px -22px rgba(var(--md-sys-color-primary-rgb), 0.8));
  }
</style>

<script>
  import { initThemeToggle } from '../../scripts/ui/theme-toggle';
  
  // 初始化主题切换
  initThemeToggle();
</script>
