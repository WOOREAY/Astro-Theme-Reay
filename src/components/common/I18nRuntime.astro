---
/**
 * I18nRuntime
 * Early client-side translation runtime for static pages.
 *
 * The site is statically rendered in the default language, so the runtime
 * translates nodes as soon as they enter the DOM and before Astro swaps pages.
 */
import { defaultLang, translations } from '../../data/i18n.config';

const payload = JSON.stringify({ defaultLang, translations }).replace(/</g, '\\u003c');
---

<script is:inline define:vars={{ payload }}>
  (function() {
    var config = JSON.parse(payload);
    var supported = Object.keys(config.translations);
    var fallbackLang = config.defaultLang;
    var observer = null;

    function normalizeLang(lang) {
      return supported.indexOf(lang) >= 0 ? lang : fallbackLang;
    }

    function getCurrentLang() {
      try {
        return normalizeLang(localStorage.getItem('language') || fallbackLang);
      } catch (_) {
        return fallbackLang;
      }
    }

    function getTranslation(key, lang) {
      var dict = config.translations[lang] || {};
      var fallback = config.translations[fallbackLang] || {};
      return dict[key] || fallback[key] || key;
    }

    function setDocumentLang(doc, lang) {
      var html = doc.documentElement;
      html.dataset.lang = lang;
      html.lang = lang === 'zh' ? 'zh-CN' : 'en';
    }

    function translateElement(element, lang) {
      if (!element || element.nodeType !== 1 || !element.hasAttribute('data-i18n')) return;

      var key = element.getAttribute('data-i18n');
      var attr = element.getAttribute('data-i18n-attr');
      if (!key) return;

      var value = getTranslation(key, lang);
      if (attr) {
        element.setAttribute(attr, value);
      } else if (element.hasAttribute('data-text')) {
        element.setAttribute('data-text', value);
      } else {
        element.textContent = value;
      }
      element.setAttribute('data-i18n-ready', 'true');
    }

    function translateTree(root, lang) {
      if (!root) return;

      var scope = root.nodeType === 9 ? root : root.ownerDocument || document;
      var currentLang = normalizeLang(lang || getCurrentLang());
      setDocumentLang(scope, currentLang);

      if (root.nodeType === 1) {
        translateElement(root, currentLang);
      }

      var elements = root.querySelectorAll ? root.querySelectorAll('[data-i18n]') : [];
      for (var i = 0; i < elements.length; i++) {
        translateElement(elements[i], currentLang);
      }
    }

    function startObserver() {
      if (observer || !window.MutationObserver) return;

      observer = new MutationObserver(function(mutations) {
        var lang = getCurrentLang();
        for (var i = 0; i < mutations.length; i++) {
          var mutation = mutations[i];

          if (mutation.type === 'attributes') {
            translateElement(mutation.target, lang);
            continue;
          }

          for (var j = 0; j < mutation.addedNodes.length; j++) {
            var node = mutation.addedNodes[j];
            if (node.nodeType === 1) {
              translateTree(node, lang);
            }
          }
        }
      });

      observer.observe(document.documentElement, {
        subtree: true,
        childList: true,
        attributes: true,
        attributeFilter: ['data-i18n', 'data-i18n-attr', 'data-text'],
      });
    }

    function applyLanguage(lang, root) {
      var currentLang = normalizeLang(lang || getCurrentLang());
      var doc = root && root.nodeType === 9 ? root : document;
      doc.documentElement.classList.add('i18n-syncing');
      translateTree(root || doc, currentLang);
      requestAnimationFrame(function() {
        doc.documentElement.classList.remove('i18n-syncing');
        doc.documentElement.classList.add('i18n-ready');
      });
      return currentLang;
    }

    window.__REAY_I18N__ = {
      defaultLang: fallbackLang,
      translations: config.translations,
      getCurrentLang: getCurrentLang,
      translate: getTranslation,
      applyLanguage: applyLanguage,
    };

    var initialLang = applyLanguage(getCurrentLang(), document);
    startObserver();

    document.addEventListener('DOMContentLoaded', function() {
      applyLanguage(initialLang, document);
    });

    window.addEventListener('languagechange', function(event) {
      var nextLang = normalizeLang(event.detail && event.detail.lang ? event.detail.lang : getCurrentLang());
      applyLanguage(nextLang, document);
    });

    document.addEventListener('astro:before-swap', function(event) {
      var nextDocument = event.newDocument || (event.detail && event.detail.newDocument);
      if (nextDocument) {
        applyLanguage(getCurrentLang(), nextDocument);
      }
    });

    document.addEventListener('astro:after-swap', function() {
      applyLanguage(getCurrentLang(), document);
      startObserver();
    });
  })();
</script>
